{# Set up CVA for the layout wrapper #}
{% set layout_variants =
  html_cva(
    base: ['component', 'grid', 'relative', 'flex', 'flex-col', 'items-stretch'],
    variants: {
      marginTop: {
        '0': 'mt-0',
        '4': 'mt-4',
        '8': 'mt-6 md:mt-7 xl:mt-8',
        '12': 'mt-8 md:mt-10 xl:mt-12',
        '16': 'mt-10 md:mt-14 xl:mt-16',
        '24': 'mt-16 md:mt-20 xl:mt-24',
        '32': 'mt-20 md:mt-24 xl:mt-32'
      },
      marginBottom: {
        '0': 'mb-0',
        '4': 'mb-4',
        '8': 'mb-6 md:mb-7 xl:mb-8',
        '12': 'mb-8 md:mb-10 xl:mb-12',
        '16': 'mb-10 md:mb-14 xl:mb-16',
        '24': 'mb-16 md:mb-20 xl:mb-24',
        '32': 'mb-20 md:mb-24 xl:mb-32'
      },
      paddingTop: {
        '0': 'pt-0',
        '4': 'pt-4',
        '8': 'pt-6 md:pt-7 xl:pt-8',
        '12': 'pt-8 md:pt-10 xl:pt-12',
        '16': 'pt-10 md:pt-14 xl:pt-16',
        '24': 'pt-16 md:pt-20 xl:pt-24',
        '32': 'pt-20 md:pt-24 xl:pt-32'
      },
      paddingBottom: {
        '0': 'pb-0',
        '4': 'pb-4',
        '8': 'pb-6 md:pb-7 xl:pb-8',
        '12': 'pb-8 md:pb-10 xl:pb-12',
        '16': 'pb-10 md:pb-14 xl:pb-16',
        '24': 'pb-16 md:pb-20 xl:pb-24',
        '32': 'pb-20 md:pb-24 xl:pb-32'
      }
    }
  )
%}

{% set layout_classes =
  layout_variants.apply({
    marginTop: margin_top|default('0'),
    marginBottom: margin_bottom|default('0'),
    paddingTop: padding_top|default('0'),
    paddingBottom: padding_bottom|default('0')
  })
%}

{# Set up CVA for the container #}
{% set container_variants =
  html_cva(
    base: '',
    variants: {
      containerType: {
        'container--edgy': 'w-full',
        'container--wide': 'w-full px-4',
        'container--normal': 'container mx-auto px-4',
        'container--narrow': 'container mx-auto px-4 w-full lg:max-w-[80%]'
      }
    }
  )
%}

{% set container_classes =
  container_variants.apply({
    containerType: container|default('container--normal')
  })
%}

{# Set up CVA for the grid #}
{% set grid_variants =
  html_cva(
    base: [
      'grid',
      'w-full',
      'gap-4',
      'md:gap-6',
      'xl:gap-8',
      'min-w-0',
      '[&>*]:w-full',
      '[&>*]:min-w-0'
    ],
    variants: {
      columnWidths: {
        'grid-col-widths--100': 'grid-cols-1',
        'grid-col-widths--50-50': 'md:grid-cols-2',
        'grid-col-widths--33-33-33': 'md:grid-cols-3',
        'grid-col-widths--75-25': 'md:grid-cols-[minmax(0,3fr)_minmax(0,1fr)]',
        'grid-col-widths--25-75': 'md:grid-cols-[minmax(0,1fr)_minmax(0,3fr)]',
        'grid-col-widths--67-33': 'md:grid-cols-[minmax(0,2fr)_minmax(0,1fr)]',
        'grid-col-widths--33-67': 'md:grid-cols-[minmax(0,1fr)_minmax(0,2fr)]',
        'grid-col-widths--50-25-25': 'md:grid-cols-[minmax(0,2fr)_minmax(0,1fr)_minmax(0,1fr)]',
        'grid-col-widths--25-25-50': 'md:grid-cols-[minmax(0,1fr)_minmax(0,1fr)_minmax(0,2fr)]',
        'grid-col-widths--25-25-25-25': 'grid-cols-1 sm:grid-cols-2 lg:grid-cols-4'
      }
    }
  )
%}

{% set grid_classes =
  grid_variants.apply({
    columnWidths: column_widths|default('grid-col-widths--75-25')
  })
%}

{# Cell base classes #}
{% set cell_classes = 'flex flex-col gap-4' %}

{# Palette class #}
{% set palette_class = palette|default('') %}

{% set texture_class = texture ?: '' %}

{# Derive column count from column_widths by counting hyphen-separated values #}
{% set widths_value = column_widths|default('grid-col-widths--75-25') %}
{% set widths_suffix = widths_value|replace({'grid-col-widths--': ''}) %}
{% set column_count = widths_suffix|split('-')|length %}

<div class="{{ layout_classes }} {{ palette_class }} {{ texture_class }}" {{ attributes }}>
  <div class="component__content {{ container_classes }}">
    <div class="{{ grid_classes }} relative">
      {% for row in 1..row_count|default(1) %}
        {% set prev_row_cell_count = (row - 1) * column_count %}
        {% for col in 1..column_count %}
          {% set current_cell = prev_row_cell_count + col %}
          <div class="{{ cell_classes }}">
            {% if block('cell_' ~ current_cell) is defined %}
              {{ block('cell_' ~ current_cell) }}
            {% endif %}
          </div>
        {% endfor %}
      {% endfor %}
    </div>

    {% set backgrounds_content %}
      {% block backgrounds %}{% endblock %}
    {% endset %}
    {% if backgrounds_content|trim is not empty %}
      <div class="component__backgrounds">
        {{ backgrounds_content }}
      </div>
    {% endif %}

    <div class="relative z-10">
      {% block behaviors %}{% endblock %}
    </div>
  </div>

  {% if overlay %}
    <div class="absolute inset-0 component__overlay overlay {{ overlay }}"></div>
  {% endif %}
</div>
