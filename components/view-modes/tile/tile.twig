{% set classes = [
  'tile'
] %}

{% set tile_content %}
  {% if image %}
    <div class="tile__image">
      {{ include('morphos:image', { image }, with_context = false) }}
    </div>
  {% endif %}

  <div class="tile__content">
    {% if info %}
      <div class="tile__info">
        {{ info }}
      </div>
    {% endif %}
    {% if heading %}
      {{ include('morphos:heading', {
        heading,
        level: heading_level|default(3),
        additional_classes: 'tile__title',
      },
        with_context: false
      ) }}
    {% endif %}
  </div>
{% endset %}

<div{{ attributes.addClass(classes) }}>
  {% if url %}
    <a href="{{ url }}" class="tile__link">
      {{ tile_content }}
    </a>
  {% else %}
    {{ tile_content }}
  {% endif %}
</div>
