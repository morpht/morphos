{% set alert_action_attributes = create_attribute() %}

{% set classes = [
  'alert',
  style,
  direction,
  color ? color : 'color--info',
  'w-full',
  'has-rhythm',
] %}

{% set action_classes = [
  'alert__action',
  canvas_is_preview ? '[&>*]:min-w-20',
] %}

<div{{ attributes.setAttribute('role', 'alert').addClass(classes) }}>
  <div class="alert__icon">
    {{ include('morphos:icon', {
      icon,
      icon_size: 'icon-size--sm',
    },
      with_context: false
    ) }}
  </div>

  <div class="alert__content">
    {{- message -}}
  </div>

  <div{{ alert_action_attributes.addClass(action_classes) }}>
    {% block buttons %}{% endblock %}
  </div>
</div>
