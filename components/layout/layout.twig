{% set is_preview = canvas_is_preview or in_preview %}

{% set container_attributes = create_attribute() %}
{% set content_attributes = create_attribute() %}
{% set sidebar_attributes = create_attribute() %}
{% set bottom_attributes = create_attribute() %}
{% set overlay_attributes = create_attribute() %}

{% set slot_main %}{% block main %}{% endblock %}{% endset %}
{% set slot_side %}{% block side %}{% endblock %}{% endset %}
{% set slot_bottom %}{% block bottom %}{% endblock %}{% endset %}
{% set slot_backgrounds %}{% block backgrounds %}{% endblock %}{% endset %}
{% set slot_behaviors %}{% block behaviors %}{% endblock %}{% endset %}

{% set margin = [
  margin_top == '0' ? 'mt-0',
  margin_top == '4' ? 'mt-4',
  margin_top == '8' ? 'mt-6 lg:mt-8',
  margin_top == '12' ? 'mt-8 md:mt-10 lg:mt-12',
  margin_top == '16' ? 'mt-10 md:mt-12 lg:mt-16',
  margin_top == '24' ? 'mt-16 md:mt-20 lg:mt-24',
  margin_top == '32' ? 'mt-20 md:mt-24 lg:mt-32',
  margin_bottom == '0' ? 'mb-0',
  margin_bottom == '4' ? 'mb-4',
  margin_bottom == '8' ? 'mb-6 lg:mb-8',
  margin_bottom == '12' ? 'mb-8 md:mb-10 lg:mb-12',
  margin_bottom == '16' ? 'mb-10 md:mb-12 lg:mb-16',
  margin_bottom == '24' ? 'mb-16 md:mb-20 lg:mb-24',
  margin_bottom == '32' ? 'mb-20 md:mb-24 lg:mb-32',
] %}

{% set padding = [
  padding_top == '0' ? 'pt-0',
  padding_top == '4' ? 'pt-4',
  padding_top == '8' ? 'pt-6 lg:pt-8',
  padding_top == '12' ? 'pt-8 md:pt-10 lg:pt-12',
  padding_top == '16' ? 'pt-10 md:pt-12 lg:pt-16',
  padding_top == '24' ? 'pt-16 md:pt-20 lg:pt-24',
  padding_top == '32' ? 'pt-20 md:pt-24 lg:pt-32',
  padding_bottom == '0' ? 'pb-0',
  padding_bottom == '4' ? 'pb-4',
  padding_bottom == '8' ? 'pb-6 lg:pb-8',
  padding_bottom == '12' ? 'pb-8 md:pb-10 lg:pb-12',
  padding_bottom == '16' ? 'pb-10 md:pb-12 lg:pb-16',
  padding_bottom == '24' ? 'pb-16 md:pb-20 lg:pb-24',
  padding_bottom == '32' ? 'pb-20 md:pb-24 lg:pb-32',
] %}

{% set classes = [
  'layout',
  'component',
  is_preview ? 'component--preview',
  palette,
  texture,
  overlay ? 'has-overlay',
]|merge(margin) %}

{% set container_classes = [
  'layout__container',
  'component__container',
  'grid',
  'grid-cols-12',
  'gap-4 lg:gap-6',
  container == 'container--normal' or not container ? 'container mx-auto px-4',
  container == 'container--edgy' ? 'w-full',
  container == 'container--wide' ? 'w-full px-4',
  container == 'container--narrow' ? 'container w-full lg:max-w-[80%] mx-auto px-4',
]|merge(padding) %}

{% set is_single_column = layout == 'layout--12' ? true : false %}
{% set is_aside_render = slot_side|render|striptags('<drupal-render-placeholder><img><figure><div><button>')|trim ? true : false %}

{% set content_classes = [
  'layout__content',
  'col-span-12',
  layout == 'layout--9-3' ? 'sm:col-span-9 order-1',
  layout == 'layout--8-1-3' ? 'sm:col-span-8 order-1',
  layout == 'layout--8-4' ? 'sm:col-span-8 order-1',
  layout == 'layout--7-1-4' ? 'sm:col-span-7 order-1',
  layout == 'layout--7-5' ? 'sm:col-span-7 order-1',
  layout == 'layout--6-1-5' ? 'sm:col-span-6 order-1',
  layout == 'layout--6m-6' ? 'sm:col-span-6 order-1',
  layout == 'layout--3-9' ? 'sm:col-span-9 order-2',
  layout == 'layout--3-1-8' and is_aside_render ? 'sm:col-start-5',
  layout == 'layout--3-1-8' ? 'sm:col-span-8 order-2',
  layout == 'layout--4-8' ? 'sm:col-span-8 order-2',
  layout == 'layout--4-1-7' and is_aside_render ? 'sm:col-start-6',
  layout == 'layout--4-1-7' ? 'sm:col-span-7 order-2',
  layout == 'layout--5-7' ? 'sm:col-span-7 order-2',
  layout == 'layout--5-1-6' and is_aside_render ? 'sm:col-start-7',
  layout == 'layout--5-1-6' ? 'sm:col-span-6 order-2',
  layout == 'layout--6-6m' ? 'sm:col-span-6 order-2',
] %}

{% set sidebar_classes = [
  'layout__sidebar',
  'col-span-12',
  layout == 'layout--9-3' ? 'sm:col-span-3 order-2',
  layout == 'layout--8-1-3' ? 'sm:col-start-10 sm:col-span-3 order-2',
  layout == 'layout--8-4' ? 'sm:col-span-4 order-2',
  layout == 'layout--7-1-4' ? 'sm:col-start-9 sm:col-span-4 order-2',
  layout == 'layout--7-5' ? 'sm:col-span-5 order-2',
  layout == 'layout--6-1-5' ? 'sm:col-start-8 sm:col-span-5 order-2',
  layout == 'layout--6m-6' ? 'sm:col-span-6 order-2',
  layout == 'layout--3-9' ? 'sm:col-span-3 order-1',
  layout == 'layout--3-1-8' ? 'sm:col-span-3 order-1',
  layout == 'layout--4-8' ? 'sm:col-span-4 order-1',
  layout == 'layout--4-1-7' ? 'sm:col-span-4 order-1',
  layout == 'layout--5-7' ? 'sm:col-span-5 order-1',
  layout == 'layout--5-1-6' ? 'sm:col-span-5 order-1',
  layout == 'layout--6-6m' ? 'sm:col-span-6 order-1',
] %}

{% set bottom_classes = [
  'layout__bottom',
  'col-span-12',
  'order-3'
] %}

{% set component_preview %}
  <div{{ attributes.addClass(classes) }}>
    <div{{ container_attributes.addClass(container_classes) }}>
      <div{{ content_attributes.addClass(content_classes) }}>
        {{ slot_main }}
      </div>
      {% if not is_single_column %}
        <div{{ sidebar_attributes.addClass(sidebar_classes) }}>
          {{ slot_side }}
        </div>
      {% endif %}
      <div{{ bottom_attributes.addClass(bottom_classes) }}>
        {{ slot_bottom }}
      </div>
    </div>
    <div class="component__backgrounds">
      {{ slot_backgrounds }}
    </div>
    <div{{ overlay_attributes.addClass('component__overlay', overlay) }}></div>
    <div class="component__behaviors">
      {{ slot_behaviors }}
    </div>
  </div>
{% endset %}

{% set component_render %}
  <div{{ attributes.addClass(classes) }}>
    <div{{ container_attributes.addClass(container_classes) }}>
      <div{{ content_attributes.addClass(content_classes) }}>
        {{ slot_main }}
      </div>
      {% if not is_single_column %}
        {% if is_aside_render %}
          <div{{ sidebar_attributes.addClass(sidebar_classes) }}>
            {{ slot_side }}
          </div>
        {% endif %}
      {% endif %}
      {% if slot_bottom|render|striptags('<drupal-render-placeholder><img><figure><div><button>')|trim %}
        <div{{ bottom_attributes.addClass(bottom_classes) }}>
          {{ slot_bottom }}
        </div>
      {% endif %}
    </div>
    {% if slot_backgrounds|render|striptags('<drupal-render-placeholder><img><figure><div><button>')|trim %}
      <div class="component__backgrounds">
        {{ slot_backgrounds }}
      </div>
    {% endif %}
    {% if overlay %}
      <div{{ overlay_attributes.addClass('component__overlay', overlay) }}></div>
    {% endif %}
    {% if slot_behaviors|render|striptags('<drupal-render-placeholder><img><figure><div><button>')|trim %}
      <div class="component__behaviors">
        {{ slot_behaviors }}
      </div>
    {% endif %}
  </div>
{% endset %}

{{ is_preview ? component_preview : component_render }}
