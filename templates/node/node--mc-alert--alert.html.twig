{{ attach_library('morphos/alert_banner') }}

{% set alert_id = node.id %}
{% set alert_type = content.field_mc_alert_type[0]['#markup']|lower ?: 'info' %} 

{% set classes = [
  'color--' ~ alert_type,
  'alert-banner',
  'flex',
  'hidden'
] %}

{# We add data-alert-id to identify this specific message #}
<div {{ attributes.addClass(classes).setAttribute('data-alert-id', alert_id) }}>
  <div class="container mx-auto flex items-center justify-between"> 
    {{ include('morphos:alert', {
      message: label,
      color: 'color--' ~ alert_type,
      icon: content.field_mc_icon[0]['#icon_id'] ?? 'info',
      style: 'alert-dash',
      direction: 'alert-horizontal'
    }, with_context = false) }}
    
    <div class="alert-banner__btn-close-wrapper px-4">
      <button
        type="button"
        class="alert-banner__btn-close btn btn-primary btn-ghost btn-circle btn-xs"
        aria-label="Close"
      >
        {{ include('morphos:icon', {
          icon: 'x',
          icon_size: 'icon-size--xs',
        },
          with_context: false
        ) }}
      </button>
    </div>
  </div> 
</div>